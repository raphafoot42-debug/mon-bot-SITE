# ════════════════════════════════════════════════════════════════
# NEXA AI — Variables d'environnement
# ⚠️ Ce fichier est un TEMPLATE — ne jamais committer les vraies valeurs
# Toutes ces variables doivent être configurées dans Netlify UI :
# Settings > Environment variables
# ════════════════════════════════════════════════════════════════

# ── SUPABASE ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY → dans Netlify UI uniquement
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── STRIPE ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE
MY_STRIPE_ACCOUNT_ID=acct_YOUR_ACCOUNT_ID_HERE

# PRICE IDs : Stripe Dashboard → Products → Copy Price ID
STRIPE_PRICE_STARTER=price_YOUR_STARTER_ID
STRIPE_PRICE_PRO=price_YOUR_PRO_ID
STRIPE_PRICE_STARTER_ANNUAL=price_YOUR_STARTER_ANNUAL_ID
STRIPE_PRICE_PRO_ANNUAL=price_YOUR_PRO_ANNUAL_ID

# ── ANTHROPIC (Claude IA) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_SYSTEM_PROMPT=YOUR_SYSTEM_PROMPT_HERE

# ── EMAIL (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE
OWNER_EMAIL=your_email@example.com

# ── TIKTOK ───────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
TIKTOK_REDIRECT_URI=https://your-site.com/tiktok-bridge.html

# ── SITE ─────────────────────────────────────────────────────────
SITE_URL=https://your-site.com
DASHBOARD_PATH=/

# ── SÉCURITÉ ─────────────────────────────────────────────────────
ADMIN_PASSWORD=your_admin_password_here

# Clé de chiffrement AES-256 pour les mots de passe TikTok clients
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ Ne jamais changer après le premier déploiement — les mots de passe existants seraient illisibles
ENCRYPTION_KEY=7adf8f4ab45fa7917ed1f65789dba3aa423a403be5b4ec02188d2149feb01def

# ── CLAUDE PROMPTS ────────────────────────────────────────────────
# Prompt du chat flottant (homepage) — si vide, utilise CLAUDE_SYSTEM_PROMPT
CLAUDE_SYSTEM_PROMPT_FLOAT=YOUR_FLOAT_CHAT_PROMPT_HERE
