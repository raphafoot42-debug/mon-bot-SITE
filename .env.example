# ════════════════════════════════════════════════════════════════
# 🔧 CONFIGURATION ENVIRONMENT
# 
# 📋 Instructions :
# 1. Copie ce fichier en ".env.local" (local dev)
# 2. Remplis tes vraies clés (voir instructions ci-dessous)
# 3. Ne JAMAIS commit .env.local (déjà dans .gitignore)
# 4. Dans Netlify UI, ajoute les vars en Settings > Environment
# ════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# 📊 SUPABASE
# https://supabase.com → Créer projet → Project Settings → API
# ════════════════════════════════════════════════════════════════

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ════════════════════════════════════════════════════════════════
# 💳 STRIPE
# https://dashboard.stripe.com → API keys → Secret key (commencer par sk_)
# ════════════════════════════════════════════════════════════════

STRIPE_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY_HERE
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# PRICE IDs : Stripe Dashboard → Products → Copy Price ID
STRIPE_PRICE_STARTER=price_1THSyjP8svYH1bkOt686fqqC
STRIPE_PRICE_PRO=price_1THSzsP8svYH1bkOndl82cmU
STRIPE_PRICE_STARTER_ANNUAL=price_1TT4VCP8svYH1bkOmrlIYHls
STRIPE_PRICE_PRO_ANNUAL=price_1TT4WjP8svYH1bkO9lOHz2CW
# Plans business/elite/partner supprimés — forfaits réels : Starter €39, Pro €59, Ambassadeur gratuit

# ════════════════════════════════════════════════════════════════
# 🤖 ANTHROPIC (Claude API)
# https://console.anthropic.com → API keys
# ════════════════════════════════════════════════════════════════

CLAUDE_API_KEY=sk-ant-YOUR_API_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_SYSTEM_PROMPT=YOUR_SYSTEM_PROMPT_HERE

# ════════════════════════════════════════════════════════════════
# 🎵 TIKTOK OAUTH
# https://developer.tiktok.com → Créer app → App credentials
# ════════════════════════════════════════════════════════════════

TIKTOK_CLIENT_KEY=sbaw1dltizgdnu9xs8
TIKTOK_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
TIKTOK_REDIRECT_URI=https://nexaai.fr/tiktok-bridge.html

# ════════════════════════════════════════════════════════════════
# 🌐 SITE CONFIG
# ════════════════════════════════════════════════════════════════

SITE_URL=https://nexaai.fr
DASHBOARD_PATH=/

# ════════════════════════════════════════════════════════════════
# 🔐 SECURITY
# Génère avec: openssl rand -hex 32
# ════════════════════════════════════════════════════════════════

NEXA_FUNCTION_SECRET=une_clé_aléatoire_très_longue_32_caractères_minimum
ADMIN_PASSWORD=un_mot_de_passe_admin_très_fort_ici

# ════════════════════════════════════════════════════════════════
# 📝 NOTES
# ════════════════════════════════════════════════════════════════

# - Toutes ces clés DOIVENT être configurées dans Netlify aussi
#   (Settings > Build & deploy > Environment variables)
#
# - Ne pas utiliser les clés de TEST (begins with pk_test, sk_test)
#   en production. Utiliser les LIVE keys (pk_live, sk_live)
#
# - Les functions Netlify ont accès via process.env.*
#   Le frontend a accès via import ou process.env en dev
#
# - Pour local dev avec .env.local, utiliser netlify-cli:
#   npm install -g netlify-cli
#   netlify dev
#
# - Cela charge .env.local ET simule les functions localement
