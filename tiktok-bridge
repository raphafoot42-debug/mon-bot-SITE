<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion TikTok — NEXA AI</title>
  <link rel="stylesheet" href="/netlify/css/nexa.css">
  <style>
    body { background:#000; color:#fff; display:flex; justify-content:center; align-items:center; min-height:100vh; font-family:'Inter',Arial,sans-serif; margin:0; }
    .box { background:#111; border:1px solid #222; border-radius:16px; padding:48px 40px; max-width:420px; width:100%; text-align:center; }
    .logo { color:#39ff14; font-size:1.8rem; font-weight:900; letter-spacing:2px; margin-bottom:24px; }
    .spinner { width:40px; height:40px; border:3px solid #333; border-top:3px solid #39ff14; border-radius:50%; animation:spin 0.8s linear infinite; margin:0 auto 20px; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .status { color:#aaa; font-size:0.95rem; }
    .status.error { color:#ff6b6b; }
    .btn-back { display:inline-block; margin-top:24px; background:#222; color:#fff; border:none; border-radius:8px; padding:12px 24px; cursor:pointer; font-size:0.9rem; text-decoration:none; }
    .btn-back:hover { background:#333; }
  </style>
</head>
<body>
  <div class="box">
    <div class="logo">NEXA AI</div>
    <div class="spinner" id="spinner"></div>
    <p class="status" id="status">Connexion TikTok en cours...</p>
    <a href="/" class="btn-back" id="btn-back" style="display:none;">← Retour au site</a>
  </div>

<script>
function setStatus(msg, isError = false) {
  const el = document.getElementById("status");
  el.textContent = msg;
  el.className = "status" + (isError ? " error" : "");
}

function showBack() {
  document.getElementById("btn-back").style.display = "inline-block";
  document.getElementById("spinner").style.display = "none";
}

async function handleCallback() {
  const params = new URLSearchParams(window.location.search);
  const code = params.get("code");
  const state = params.get("state");
  const error = params.get("error");

  // Gère erreur TikTok
  if (error) {
    setStatus("❌ Connexion TikTok refusée : " + decodeURIComponent(error), true);
    showBack();
    return;
  }

  // Pas de code
  if (!code) {
    setStatus("❌ Aucun code reçu de TikTok", true);
    showBack();
    return;
  }

  // Vérifie PKCE verifier
  const verifier = sessionStorage.getItem("pkce_verifier");
  if (!verifier) {
    setStatus("❌ Session expirée. Recommence la connexion.", true);
    showBack();
    return;
  }

  // Vérifie CSRF state
  const expectedState = sessionStorage.getItem("oauth_state");
  if (expectedState && state && expectedState !== state) {
    setStatus("❌ Erreur de sécurité (state invalide). Recommence.", true);
    showBack();
    return;
  }

  setStatus("⏳ Échange du code TikTok...");

  try {
    const response = await fetch("/.netlify/functions/tiktok-callback", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ code, verifier, state }),
    });

    const data = await response.json();

    if (!response.ok || data.success !== true) {
      throw new Error(data.message || data.error || "Erreur inconnue");
    }

    // Nettoyage
    sessionStorage.removeItem("pkce_verifier");
    sessionStorage.removeItem("oauth_state");

    setStatus("✅ Connexion réussie ! Redirection...");

    setTimeout(() => {
      window.location.href = "/?tiktok=success";
    }, 1000);

  } catch (err) {
    setStatus("❌ Erreur : " + (err.message || "inconnue"), true);
    showBack();
  }
}

window.addEventListener("load", handleCallback);
</script>
</body>
</html>
